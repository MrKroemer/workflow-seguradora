# ============================================================
# RPA Corretora - Template de ambiente (.env.example)
# Ambiente-alvo: Windows
# Copie para .env e preencha apenas os valores necessarios.
# ============================================================

# ----------------------------
# Modo producao estrito (sem fallback)
# ----------------------------
RPA_STRICT_PRODUCTION=0
MICROSOFT_TODO_REQUIRE_DESKTOP=0

# ----------------------------
# Google Calendar
# ----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEOUT_SECONDS=20
# Mapeamento de cores do Google Agenda (colorId do evento):
# vermelho -> cobranca de parcelas
# azul -> baixa de parcelas
# cinza -> acompanhamento de sinistros
# verde -> tratativas diversas
# amarelo -> aviso de liberacao de cobranca em conta
# tangerina -> boleto/parcela em atraso
# Dica: se voce usa tons claros/alternativos no Google Agenda, pode incluir mais IDs,
# por exemplo AZUL=1,7,9 e VERMELHO=4,6,11.
GOOGLE_COLOR_IDS_VERMELHO=4,11
GOOGLE_COLOR_IDS_AZUL=9
GOOGLE_COLOR_IDS_CINZA=8
GOOGLE_COLOR_IDS_VERDE=10
GOOGLE_COLOR_IDS_AMARELO=5
GOOGLE_COLOR_IDS_TANGERINA=6

# ----------------------------
# Microsoft To Do (Graph)
# ----------------------------
MICROSOFT_TODO_CLIENT_ID=
MICROSOFT_TODO_CLIENT_SECRET=
MICROSOFT_TODO_REFRESH_TOKEN=
MICROSOFT_TODO_TENANT_ID=common
# Nome da lista a ser usada para criacao/atualizacao das tarefas do bot
# (ex.: "Principal", "Tasks", "Tarefas")
MICROSOFT_TODO_LIST_NAME=Principal
MICROSOFT_TODO_DESKTOP_ENABLED=1
MICROSOFT_TODO_DESKTOP_TIMEOUT_SECONDS=40

# ----------------------------
# Microsoft To Do (automacao web de fallback no Windows)
# ----------------------------
# O modo prioritario e DESKTOP_APP (app nativo). Este bloco e fallback.
MICROSOFT_TODO_USER=
MICROSOFT_TODO_PASSWORD=
MICROSOFT_TODO_WEB_HEADLESS=1

# Caminho opcional dos browsers do Playwright (normalmente pode ficar vazio)
# Exemplo Windows:
# PLAYWRIGHT_BROWSERS_PATH=C:\Users\SEU_USUARIO\AppData\Local\ms-playwright
PLAYWRIGHT_BROWSERS_PATH=

# ----------------------------
# Credenciais de Portais das Seguradoras
# ----------------------------
YELUM_PORTAL_USER=
YELUM_PORTAL_PASSWORD=
YELUM_PORTAL_WEB_HEADLESS=1

PORTO_PORTAL_USER=
PORTO_PORTAL_PASSWORD=
PORTO_PORTAL_WEB_HEADLESS=1

MAPFRE_PORTAL_USER=
MAPFRE_PORTAL_PASSWORD=
MAPFRE_PORTAL_WEB_HEADLESS=1

BRADESCO_PORTAL_USER=
BRADESCO_PORTAL_PASSWORD=
BRADESCO_PORTAL_WEB_HEADLESS=1

ALLIANZ_PORTAL_USER=
ALLIANZ_PORTAL_PASSWORD=
ALLIANZ_PORTAL_WEB_HEADLESS=1

SUHAI_PORTAL_USER=
SUHAI_PORTAL_PASSWORD=
SUHAI_PORTAL_WEB_HEADLESS=1

TOKIO_PORTAL_USER=
TOKIO_PORTAL_PASSWORD=
TOKIO_PORTAL_WEB_HEADLESS=1

HDI_PORTAL_USER=
HDI_PORTAL_PASSWORD=
HDI_PORTAL_WEB_HEADLESS=1

AZUL_PORTAL_USER=
AZUL_PORTAL_PASSWORD=
AZUL_PORTAL_WEB_HEADLESS=1

# Justos pode ficar em branco se estiver OFF no momento
JUSTOS_PORTAL_USER=
JUSTOS_PORTAL_PASSWORD=
JUSTOS_PORTAL_WEB_HEADLESS=1

# Se 1, tenta buscar credenciais no SENHAS.pdf quando faltarem envs
PORTAL_USE_PDF_CREDENTIALS=0

# ----------------------------
# Gmail (IMAP)
# ----------------------------
GMAIL_IMAP_USER=
GMAIL_IMAP_PASSWORD=
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_MAILBOX=INBOX
GMAIL_IMAP_MAX_MESSAGES=60

# ----------------------------
# Segfy
# ----------------------------
# Opcao 1: API (recomendado)
SEGFY_USER=
SEGFY_PASSWORD=
SEGFY_API_BASE_URL=
SEGFY_API_TOKEN=
SEGFY_API_LOGIN_PATH=/auth/login
SEGFY_API_POLICIES_PATH=/policies
SEGFY_API_REGISTER_PAYMENT_PATH=/payments/register
SEGFY_API_TIMEOUT_SECONDS=20

# Opcao 2: Web (Chrome/Playwright no Windows)
# Se 1, tenta operar o Segfy pelo navegador quando API nao estiver configurada.
SEGFY_WEB_ENABLED=1
SEGFY_WEB_BASE_URL=https://app.segfy.com
SEGFY_WEB_HEADLESS=1
SEGFY_WEB_BROWSER_CHANNEL=chrome
# Em producao estrita, mantenha 0 para falhar explicitamente se o canal configurado
# nao puder ser aberto (evita fallback silencioso para outro navegador).
SEGFY_WEB_ALLOW_CHANNEL_FALLBACK=1
SEGFY_WEB_TIMEOUT_SECONDS=35
SEGFY_WEB_IMPORT_ENABLED=1
# Pode ficar vazio para usar a rota padrao:
# https://app.segfy.com/centralVendas/importacaoPropostas
SEGFY_WEB_IMPORT_URL=
# Pasta local com arquivos PDF/Excel para importar no Segfy.
# Exemplo Windows:
# SEGFY_IMPORT_SOURCE_DIR=C:\Users\cadas\OneDrive\Documentos\SEGUROS\Apolices vincendas em 2027
SEGFY_IMPORT_SOURCE_DIR=
SEGFY_WEB_IMPORT_MAX_FILES=100
# Estado de monitoramento da pasta de importacao (ultima execucao do robô).
# Arquivos com data de criacao/modificacao posterior a esse marco serao tratados como novos.
SEGFY_IMPORT_STATE_PATH=outputs/segfy_import_state.json
# Habilita tentativa de baixa de pagamentos (agenda AZUL) via automacao web.
SEGFY_WEB_PAYMENT_ENABLED=1
# Pode ficar vazio para o bot tentar rotas padrao do financeiro.
SEGFY_WEB_PAYMENT_URL=

# Opcao 3: leitura por exportacao
SEGFY_EXPORT_XLSX=

# ----------------------------
# WhatsApp (API externa)
# ----------------------------
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_TOKEN=
WHATSAPP_AUTH_HEADER=Authorization
WHATSAPP_AUTH_SCHEME=Bearer
WHATSAPP_TIMEOUT_SECONDS=20

# ----------------------------
# SMTP / E-mails de notificacao
# ----------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=1
SMTP_TIMEOUT_SECONDS=20

# Destino para notificacoes de compromisso VERDE
INSURED_NOTIFY_EMAIL_TO=
# Destino para alertas operacionais de recebimento Nubank.
# Se vazio, usa EXECUTION_REPORT_EMAIL_TO e depois INSURED_NOTIFY_EMAIL_TO como fallback.
CORRETORA_NOTIFY_EMAIL_TO=

# Estado de deduplicacao dos disparos (evita reenvio do mesmo evento).
MESSAGE_DISPATCH_STATE_PATH=outputs/message_dispatch_state.json

# ----------------------------
# Relatorio de execucao (JSON + PDF + envio por e-mail)
# ----------------------------
EXECUTION_REPORT_EMAIL_TO=

# Pasta local para relatorios.
# Exemplo Windows:
# EXECUTION_REPORT_OUTPUT_DIR=C:\RPA\outputs
EXECUTION_REPORT_OUTPUT_DIR=

# ----------------------------
# Arquivos operacionais (planilhas/PDF)
# ----------------------------
# Se voce usar --files-dir, pode deixar em branco.
# Exemplo Windows:
# SEGUROS_PBSEG_XLSX=C:\RPA\arquivos\SEGUROS PBSEG.xlsx
# ACOMPANHAMENTO_2026_XLSX=C:\RPA\arquivos\ACOMPANHAMENTO 2026.xlsx
# FLUXO_CAIXA_XLSX=C:\RPA\arquivos\FLUXO DE CAIXA.xlsx
# SENHAS_PDF=C:\RPA\arquivos\SENHAS.pdf
SEGUROS_PBSEG_XLSX=
ACOMPANHAMENTO_2026_XLSX=
FLUXO_CAIXA_XLSX=
SENHAS_PDF=
